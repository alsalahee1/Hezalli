# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Only variable NAMES belong here — no real secrets.

# --- Database (PostgreSQL) ---
# Create a free database on Neon (https://neon.tech) or Supabase
# (https://supabase.com) and paste its connection string here.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL=

# --- App ---
# Public base URL of the app (used for absolute links, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Phase 3) ---
# Secret used to sign/encrypt the session JWT. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=
# Base URL Auth.js uses for callbacks. In local dev this is the app URL.
AUTH_URL=http://localhost:3000
# Google OAuth credentials are added in Step 3.3.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# Passwordless one-click "fast login" at /dev-login for testing seed accounts.
# Leave UNSET in production — when "true" it lets anyone sign in as a seed
# account (admin, seller, courier, buyer) with no password.
# DEV_LOGIN_ENABLED=true

# --- Web Push (driver notifications; optional) ---
# Pings couriers' phones when a parcel is assigned, even with the app closed.
# The feature no-ops until BOTH keys are set. Generate a pair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY is served to the browser; keep VAPID_PRIVATE_KEY secret.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@hezalli.com

# --- File storage (Phase 5) ---
# Driver: "local" (dev — files under .uploads/, no bucket needed) or "s3"
# (production — any S3-compatible bucket). See docs/STORAGE.md for setup.
STORAGE_DRIVER=local
# The S3_* vars are only needed when STORAGE_DRIVER=s3 (Cloudflare R2 shown):
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=hezalli-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://<your-public-bucket-domain>

# --- Scheduled jobs (Phase 16) ---
# Shared secret for the cron endpoint (/api/cron/auto-complete). Vercel Cron
# sends it automatically as `Authorization: Bearer $CRON_SECRET`.
#   openssl rand -base64 32
CRON_SECRET=

# --- Monitoring (Phase 16.2) ---
# Set to enable error tracking (see lib/observability.ts plug-in point).
# SENTRY_DSN=

# --- Seeding guard (Phase 16.1) ---
# The seed WIPES the database. It refuses to run when NODE_ENV=production
# unless SEED_ALLOWED=true is also set. Never set this in production.
# SEED_ALLOWED=true

# --- AI shopping assistant (Gemini) ---
# API key for Google Gemini, used by the storefront AI assistant widget.
# Get one free at https://aistudio.google.com/apikey . When unset, the
# assistant widget stays hidden and /api/ai-chat returns 503.
GEMINI_API_KEY=
# Optional: override the model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- Telegram bot (optional) ---
# Lets the same AI assistant answer inside Telegram. Create a bot with
# @BotFather (/newbot) and paste its token here. When unset, the Telegram
# webhook endpoint quietly does nothing.
TELEGRAM_BOT_TOKEN=
# Shared secret Telegram echoes back on every update so the webhook can verify
# the caller. Generate one with:  openssl rand -hex 16
TELEGRAM_WEBHOOK_SECRET=
# After deploying (NEXT_PUBLIC_APP_URL must be a public HTTPS URL), register
# the webhook once with:  npm run telegram:webhook
# Account linking: users send /link in the bot and confirm on the site. No
# extra config needed (uses NEXT_PUBLIC_APP_URL).

# --- WhatsApp bot (optional; Meta WhatsApp Cloud API) ---
# Same AI assistant on WhatsApp. Create an app at developers.facebook.com,
# add the WhatsApp product, and copy these from the API setup page. When
# WHATSAPP_TOKEN/PHONE_NUMBER_ID are unset the webhook quietly does nothing.
WHATSAPP_TOKEN=                  # permanent system-user access token
WHATSAPP_PHONE_NUMBER_ID=        # the sending phone number's ID
# You choose this value; enter the same string in the Meta webhook setup.
WHATSAPP_VERIFY_TOKEN=
# App secret — enables X-Hub-Signature-256 verification (recommended).
WHATSAPP_APP_SECRET=
# Optional: Graph API version and default reply language.
# WHATSAPP_API_VERSION=v21.0
# WHATSAPP_DEFAULT_LOCALE=ar     # ar | en
# Webhook callback URL to register in Meta: <NEXT_PUBLIC_APP_URL>/api/whatsapp/webhook

# --- Voice replies (optional; requires the ffmpeg binary on the host) ---
# The bot always UNDERSTANDS incoming voice notes. These control whether it
# REPLIES with voice — which needs ffmpeg (a VPS / Node host, not serverless).
# BOT_REPLY_MODE=text     # text | voice | both | match (match: voice-in → voice-out)
# BOT_TTS_VOICE=Leda      # Gemini prebuilt voice (e.g. Kore, Leda, Aoede)
# BOT_TTS_STYLE=          # optional delivery cue; defaults to a friendly tone per language
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# --- Bot cost guards (optional; sensible defaults shown) ---
# Protect the Gemini bill from spammers/loops. These apply to the messaging
# channels (Telegram), not the on-site widget.
# BOT_MAX_PER_HOUR=60      # max messages per chat per rolling hour
# BOT_DAILY_CAP=3000       # global daily message backstop across all chats
# BOT_SPEND_CAP_USD=0      # monthly spend ceiling in USD (0 = unlimited)
# Rough gemini-2.5-flash pricing used only for the spend estimate (USD / 1M tokens):
# GEMINI_PRICE_IN_PER_M=0.30
# GEMINI_PRICE_OUT_PER_M=2.50
# GEMINI_PRICE_TTS_PER_M=10.00   # TTS audio output is billed higher than text

# --- Wallet: Reloadly airtime provider (optional; Step 20) ---
# Auto-fulfils AIRTIME top-ups via the Reloadly aggregator (covers Yemen Mobile,
# Sabafon, YOU/MTN). Create a free account at reloadly.com, then set these and
# switch the `wallet_bills_provider` platform setting to "reloadly".
# Use a USD-denominated Reloadly account so the wallet's USD maps 1:1.
# RELOADLY_CLIENT_ID=
# RELOADLY_CLIENT_SECRET=
# RELOADLY_ENV=sandbox        # sandbox | live (default sandbox)
# RELOADLY_AUDIENCE=          # optional override; defaults to the live topups URL

# --- Wallet: biometric step-up (WebAuthn / passkeys; optional, Step 21) ---
# Face ID / Touch ID / fingerprint / Windows Hello to authorize wallet outflows
# instead of the PIN. rpID/origin are derived from NEXT_PUBLIC_APP_URL; override
# only for split domains or local testing. Requires HTTPS in production.
# WEBAUTHN_RP_ID=hezalli.com
# WEBAUTHN_ORIGIN=https://hezalli.com

# NOTE: payments and email variables are added in their respective phases
# (see docs/03-accounts-auth.md onward).

# Transactional email (optional in dev; emails are dropped when unset)
# RESEND_API_KEY=
# EMAIL_FROM=Hezalli <no-reply@hezalli.com>

# Error tracking (optional; console-only when unset)
# SENTRY_DSN=
