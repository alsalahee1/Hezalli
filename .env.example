# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Only variable NAMES belong here — no real secrets.

# --- Database (PostgreSQL) ---
# Create a free database on Neon (https://neon.tech) or Supabase
# (https://supabase.com) and paste its connection string here.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL=

# --- App ---
# Public base URL of the app (used for absolute links, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Phase 3) ---
# Secret used to sign/encrypt the session JWT. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=
# Base URL Auth.js uses for callbacks. In local dev this is the app URL.
AUTH_URL=http://localhost:3000
# Google OAuth credentials are added in Step 3.3.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# --- File storage (Phase 5) ---
# Driver: "local" (dev — files under .uploads/, no bucket needed) or "s3"
# (production — any S3-compatible bucket). See docs/STORAGE.md for setup.
STORAGE_DRIVER=local
# The S3_* vars are only needed when STORAGE_DRIVER=s3 (Cloudflare R2 shown):
# S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_BUCKET=hezalli-uploads
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=https://<your-public-bucket-domain>

# --- Scheduled jobs (Phase 16) ---
# Shared secret for the cron endpoint (/api/cron/auto-complete). Vercel Cron
# sends it automatically as `Authorization: Bearer $CRON_SECRET`.
#   openssl rand -base64 32
CRON_SECRET=

# --- Monitoring (Phase 16.2) ---
# Set to enable error tracking (see lib/observability.ts plug-in point).
# SENTRY_DSN=

# --- Seeding guard (Phase 16.1) ---
# The seed WIPES the database. It refuses to run when NODE_ENV=production
# unless SEED_ALLOWED=true is also set. Never set this in production.
# SEED_ALLOWED=true

# NOTE: payments and email variables are added in their respective phases
# (see docs/03-accounts-auth.md onward).
