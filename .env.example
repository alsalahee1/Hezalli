# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Only variable NAMES belong here — no real secrets.

# --- Database (PostgreSQL) ---
# Create a free database on Neon (https://neon.tech) or Supabase
# (https://supabase.com) and paste its connection string here.
# Example: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public&sslmode=require
DATABASE_URL=

# --- App ---
# Public base URL of the app (used for absolute links, callbacks, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (Phase 3) ---
# Secret used to sign/encrypt the session JWT. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=
# Base URL Auth.js uses for callbacks. In local dev this is the app URL.
AUTH_URL=http://localhost:3000
# Google OAuth credentials are added in Step 3.3.
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# NOTE: payments, email, and storage variables are added in their respective
# phases (see docs/03-accounts-auth.md onward).
