# =============================================================================
# Hezalli — production environment for the VPS deployment.
#
# On the server:  cp .env.production.example .env  &&  edit the values below.
# This `.env` is read by docker-compose. NEVER commit the real file.
# =============================================================================

# --- Database (used by both Postgres and the app) ---
# These three build the DATABASE_URL below. Change the password!
POSTGRES_USER=hezalli
POSTGRES_PASSWORD=CHANGE_ME_to_a_long_random_password
POSTGRES_DB=hezalli

# Connection string the app and Prisma use. The host is the compose service
# name `db`. Keep it in sync with the three values above.
DATABASE_URL=postgresql://hezalli:CHANGE_ME_to_a_long_random_password@db:5432/hezalli?schema=public

# --- App ---
NEXT_PUBLIC_APP_URL=https://www.hezalli.com

# Secret used by next-auth to sign session tokens. REQUIRED — the app refuses
# to start without it. Generate one with:  openssl rand -hex 32
# (deploy/vps-deploy.sh auto-generates this if left blank.)
AUTH_SECRET=

# Passwordless one-tap login as seed accounts (/dev-login + chips on the login
# screen), for TESTING ONLY. Anyone can sign in as the seed admin when this is
# "true" — leave it unset on a real production host.
# DEV_LOGIN_ENABLED=true

# --- First admin (production bootstrap) ---
# The production deploy does NOT seed any login-able accounts (the demo seed's
# shared "hezalli123" password would be a public backdoor). After the first
# deploy, create your real admin ONCE with a strong, unique password:
#
#   ADMIN_EMAIL=you@example.com ADMIN_PASSWORD='<strong-password>' \
#     docker compose run --rm migrate npx tsx scripts/create-admin.ts
#
# Do not commit these; unset them again once the admin exists.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=

# --- Transactional email (Resend; strongly recommended) ---
# Without these, every email (order updates, password reset, newsletter) is
# silently dropped. Create a key at https://resend.com and verify your domain.
# RESEND_API_KEY=
# EMAIL_FROM=Hezalli <no-reply@hezalli.com>

# --- Error tracking (Sentry; recommended) ---
# Server errors are reported to Sentry when set; otherwise console-only.
# SENTRY_DSN=

# --- Web Push (driver notifications; optional) ---
# Pings couriers' phones on new assignments. No-ops until both keys are set.
# Generate once:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@hezalli.com

# --- TLS / domain (bundled Caddy path, used only if the server has no proxy) ---
# Space/comma separated hostnames to serve. Both must resolve to this server.
SITE_ADDRESS=hezalli.com, www.hezalli.com
# Email Let's Encrypt uses for expiry notices.
ACME_EMAIL=admin@hezalli.com

# --- Traefik coexistence (auto-filled by deploy/vps-deploy.sh) ---
# When the server already runs Traefik (e.g. the Hostinger n8n template),
# these are detected automatically and Hezalli is routed by Traefik instead
# of the bundled Caddy. Usually you do not set these by hand.
TRAEFIK_NETWORK=
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_ENTRYPOINT_HTTP=web
TRAEFIK_CERTRESOLVER=
