// Hezalli — Prisma schema (Step 2.2). Implemented from docs/DATABASE.md.
//
// Prisma 7 note: the connection URL is NOT set here. It lives in
// prisma.config.ts (Prisma CLI) and is passed to PrismaClient through the pg
// driver adapter in lib/prisma.ts (app runtime).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  BUYER
  SELLER
  ADMIN
  COURIER // Hezalli Express delivery driver
  DELIVERY_POINT // partner-operated parcel hub operator (Hezalli Point)
}

enum Currency {
  USD
  YER
  SAR
  AED
}

enum AddressType {
  SHIPPING
  STORE_PICKUP
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  REJECTED
}

// A visitor's request to become a Hezalli Express driver. Approval grants the
// COURIER role — it is never self-granted, mirroring how real fleets onboard
// (apply → verify → admin approve → activate). See lib/actions/courier-application.ts.
enum CourierApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum StoreStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  HIDDEN
  REMOVED
}

enum ProductCondition {
  NEW
  USED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum SubOrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentMethod {
  COD
  LOCAL_WALLET // external Yemeni rails: Jawali, Jaib, Floosak, Kuraimi (was WALLET)
  BANK_TRANSFER
  USDT
  HEZALLI_BALANCE // pay from the internal HezalliPay wallet — instant, no admin confirm
}

enum PaymentStatus {
  PENDING
  AWAITING_CONFIRMATION
  CONFIRMED
  FAILED
  REFUNDED
}

enum UsdtNetwork {
  TRC20
  ERC20
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  PICKED_UP
  IN_TRANSIT
  AT_POINT // received & held at a Hezalli Point (custody: point)
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED_TO_POINT // failed parcel scanned back into the point
  RETURNED
}

// Outcome of a single doorstep delivery attempt by a courier. A parcel can have
// several FAILED attempts before a DELIVERED one — see DeliveryAttempt.
enum DeliveryOutcome {
  DELIVERED
  FAILED
}

// Entries in a courier's cash + earnings ledger (see CourierLedgerEntry).
enum CourierLedgerType {
  COD_COLLECTED // + COD cash the driver took from the buyer on delivery
  REMITTANCE // − cash the driver handed in to the office
  EARNING // + the driver's delivery fee (owed by Hezalli to the driver)
  PAYOUT // − delivery fees Hezalli has paid out to the driver
  ADJUSTMENT // ± manual correction by an admin
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  IN_TRANSIT
  RECEIVED
  REFUNDED
  CLOSED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum LedgerType {
  SALE
  COMMISSION
  REFUND
  PAYOUT
  ADJUSTMENT
  COD_COMMISSION_DUE
  WALLET_TRANSFER // moved to the seller's HezalliPay wallet (Step 19.5+)
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum CouponScope {
  PLATFORM
  SELLER
}

enum DiscountType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

enum NotificationType {
  ORDER
  PAYMENT
  SHIPMENT
  RETURN
  DISPUTE
  CHAT
  PROMO
  SYSTEM
}

// ---------------------------------------------------------------------------
// A. Identity & accounts
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  phoneVerified DateTime?
  passwordHash  String?
  image         String?
  roles         Role[]    @default([BUYER])
  locale        String    @default("ar")
  notificationPrefs Json?
  isSuspended   Boolean   @default(false)
  deletedAt     DateTime?
  // Loyalty (Step 17.9): points balance + referral graph.
  loyaltyPoints Int       @default(0)
  referralCode  String?   @unique
  referredById  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  addresses      Address[]
  sellerProfile  SellerProfile?
  cart           Cart?
  wishlist       Wishlist?
  recentlyViewed RecentlyViewed[]
  orders         Order[]
  reviews        Review[]
  returnRequests ReturnRequest[]
  notifications  Notification[]
  conversations  Conversation[]
  follows        StoreFollow[]
  accounts       Account[]
  sessions       Session[]
  referredBy     User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals      User[]   @relation("Referrals")
  loyaltyTxns    LoyaltyTransaction[]
  wallet         Wallet?
  walletCredentials WalletCredential[]
  walletWebauthnChallenge WalletWebauthnChallenge?
  courierShipments Shipment[] @relation("CourierShipments")
  courierLocation  CourierLocation?
  courierApplication CourierApplication?
  courierLedger    CourierLedgerEntry[] @relation("CourierLedger")
  pushSubscriptions PushSubscription[]
  deliveryPoint    DeliveryPoint? @relation("PointOwner")
  deliveryPointApplication DeliveryPointApplication?
  // Fleet-partner tier: a courier may belong to a fleet (fleetId); a user may
  // also OWN one fleet (ownedFleet), which grants the read-only fleet portal.
  fleetId          String?
  fleet            Fleet? @relation("FleetMembers", fields: [fleetId], references: [id], onDelete: SetNull)
  ownedFleet       Fleet? @relation("FleetOwner")

  @@index([referredById])
  @@index([fleetId])
}

// A fleet-partner: a delivery company operating several Hezalli Express couriers
// under one banner. Couriers are grouped into a fleet (User.fleetId) so their
// jobs, cash-on-hand, and earnings roll up for the partner. An optional owner
// user gets a read-only fleet dashboard. Fleets are created + staffed by admins,
// never self-served (mirrors how couriers and points are onboarded).
model Fleet {
  id           String   @id @default(cuid())
  name         String
  contactPhone String?
  contactEmail String?
  ownerId      String?  @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  owner        User?    @relation("FleetOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  couriers     User[]   @relation("FleetMembers")

  @@index([isActive])
}

// A browser/device Web Push subscription. One user may have several (phone,
// desktop). Used to ping couriers when a parcel is assigned even if the driver
// app is closed. Requires VAPID keys in the server env (see lib/push.ts) — the
// whole feature no-ops when they're unset.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A courier's cash-and-earnings ledger. COD_COLLECTED (+) is buyer cash the
// driver is holding; REMITTANCE (−) is cash handed to the office; the running
// sum of those two is the driver's CASH ON HAND. EARNING (+) is the delivery
// fee Hezalli owes the driver. Amounts are signed so a plain SUM reconciles.
model CourierLedgerEntry {
  id          String            @id @default(cuid())
  courierId   String
  type        CourierLedgerType
  amountUsd   Decimal           @db.Decimal(12, 2) // signed
  subOrderId  String?
  shipmentId  String?
  note        String?
  createdById String? // admin who recorded a remittance / adjustment
  createdAt   DateTime          @default(now())
  courier     User              @relation("CourierLedger", fields: [courierId], references: [id], onDelete: Cascade)

  @@index([courierId])
  @@index([subOrderId])
}

enum DeliveryPointStatus {
  ACTIVE
  SUSPENDED
}

// A partner-operated parcel hub ("Hezalli Point"): sellers drop parcels here,
// couriers collect them via QR handover, failed deliveries flow back through
// it. The operator is a partner (not staff) and earns a per-parcel handling
// fee — see DeliveryPointLedgerEntry and docs/DELIVERY-POINTS.md.
model DeliveryPoint {
  id          String              @id @default(cuid())
  ownerId     String              @unique
  name        String
  phone       String
  governorate String
  city        String
  addressLine String
  lat         Float?
  lng         Float?
  // Max parcels held/inbound at once (null = unlimited). Gates NEW routing
  // only — counter scans always accept announced parcels. See §8 of the docs.
  capacity    Int?
  status      DeliveryPointStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  owner       User                @relation("PointOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  shipments   Shipment[]
  ledger      DeliveryPointLedgerEntry[]
  payoutRequests PointPayoutRequest[]

  @@index([governorate, status])
}

// A hub operator's request to be paid their earnings balance, mirroring the
// seller Payout flow (docs/DELIVERY-POINTS.md §22). Marking it PAID writes the
// negative PAYOUT ledger entry in the same transaction, so the request queue
// and the ledger can never disagree.
model PointPayoutRequest {
  id          String        @id @default(cuid())
  pointId     String
  amountUsd   Decimal       @db.Decimal(12, 2)
  status      PayoutStatus  @default(REQUESTED)
  note        String? // operator's note; on rejection, the admin's reason
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  point       DeliveryPoint @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@index([pointId])
  @@index([status])
}

// One "become a delivery point" application per user, mirroring
// CourierApplication: created PENDING, admin reviews; approval grants the
// DELIVERY_POINT role and creates the DeliveryPoint. Rejected applicants may
// resubmit — the row is reused and flipped back to PENDING.
model DeliveryPointApplication {
  id           String                   @id @default(cuid())
  userId       String                   @unique
  pointName    String
  fullName     String
  phone        String
  governorate  String
  city         String
  addressLine  String
  lat          Float?
  lng          Float?
  notes        String?
  status       CourierApplicationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

// Entries in a delivery point's ledger, signed. Two independent sides:
// EARNINGS (HANDLING_FEE + PAYOUT + ADJUSTMENT — what Hezalli owes the point)
// and CASH (COD_COLLECTED + COD_REMITTANCE — buyer cash the point holds on
// Hezalli's behalf from counter pickups). See lib/point-ledger.ts.
enum PointLedgerType {
  HANDLING_FEE // + fee earned when a routed parcel is delivered
  PAYOUT // − Hezalli paid the point operator
  ADJUSTMENT // ± manual correction by an admin (earnings side)
  COD_COLLECTED // + COD cash the counter took from a buyer at pickup
  DRIVER_CASH_IN // + COD cash a courier handed in at the counter (docs §12)
  COD_REMITTANCE // − cash the point handed in to Hezalli
}

model DeliveryPointLedgerEntry {
  id          String          @id @default(cuid())
  pointId     String
  type        PointLedgerType
  amountUsd   Decimal         @db.Decimal(12, 2) // signed
  subOrderId  String?
  shipmentId  String?
  note        String?
  createdById String? // admin who recorded a payout / adjustment
  createdAt   DateTime        @default(now())
  point       DeliveryPoint   @relation(fields: [pointId], references: [id], onDelete: Cascade)

  @@index([pointId])
  @@index([subOrderId])
}

// One "become a driver" application per user. Created PENDING by the applicant;
// an admin reviews it and, on approval, grants the COURIER role (see
// reviewCourierApplication). A rejected applicant may resubmit — the row is
// reused and flipped back to PENDING. Kept separate from SellerProfile because
// couriers are individuals, not stores.
model CourierApplication {
  id           String                   @id @default(cuid())
  userId       String                   @unique
  fullName     String
  phone        String
  governorate  String
  city         String
  vehicleType  String // motorbike | car | bicycle | van | foot
  notes        String?
  status       CourierApplicationStatus @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  user         User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  userId     String
  points     Int // signed: + earned/refunded, − redeemed
  type       String // EARN | REDEEM | REFERRAL | REFUND | ADJUST
  orderId    String?
  subOrderId String?
  note       String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([subOrderId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model OtpToken {
  id         String    @id @default(cuid())
  userId     String?
  channel    String
  target     String
  codeHash   String
  purpose    String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([target])
}

model Address {
  id          String      @id @default(cuid())
  userId      String
  type        AddressType @default(SHIPPING)
  fullName    String
  phone       String
  governorate String
  city        String
  line1       String
  line2       String?
  notes       String?
  // Optional pinned coordinates (buyer "pin my location"), for proximity-based
  // Hezalli Express courier routing. Null → fall back to governorate locality.
  lat         Float?
  lng         Float?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@index([userId])
}

// ---------------------------------------------------------------------------
// B. Seller & store
// ---------------------------------------------------------------------------

model SellerProfile {
  id            String         @id @default(cuid())
  userId        String         @unique
  kycStatus     KycStatus      @default(NONE)
  kycDocs       Json?
  kycReviewedBy String?
  kycReviewedAt DateTime?
  // Per-seller commission override (null = use the platform-wide rate).
  commissionRate Decimal?      @db.Decimal(5, 4)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  store         Store?
  balance       SellerBalance?
  payoutMethods PayoutMethod[]
  payouts       Payout[]
}

model Store {
  id            String         @id @default(cuid())
  sellerId      String         @unique
  name          String
  slug          String         @unique
  logo          String?
  banner        String?
  description   String?
  policies      Json?
  status        StoreStatus    @default(ACTIVE)
  isFeatured    Boolean        @default(false)
  // Seller tools (Step 17.7): temporary self-close + chat auto-reply.
  isOnVacation  Boolean        @default(false)
  vacationMessage  String?
  autoReplyMessage String?
  ratingAvg     Float          @default(0)
  ratingCount   Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  seller        SellerProfile  @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  products      Product[]
  shippingRates ShippingRate[]
  subOrders     SubOrder[]
  conversations Conversation[]
  coupons       Coupon[]
  followers     StoreFollow[]
}

model PayoutMethod {
  id        String        @id @default(cuid())
  sellerId  String
  kind      String
  details   Json
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  seller    SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

// ---------------------------------------------------------------------------
// C. Catalog
// ---------------------------------------------------------------------------

model Category {
  id       String     @id @default(cuid())
  parentId String?
  name     Json
  slug     String     @unique
  icon     String?
  position Int        @default(0)
  isActive Boolean    @default(true)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  logo     String?
  products Product[]
}

model StoreFollow {
  id        String   @id @default(cuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
}

model Product {
  id               String           @id @default(cuid())
  storeId          String
  categoryId       String
  brandId          String?
  title            Json
  slug             String           @unique
  description      Json?
  status           ProductStatus    @default(ACTIVE)
  condition        ProductCondition @default(NEW)
  basePrice        Decimal          @db.Decimal(12, 2)
  lowStockThreshold Int             @default(0)
  weightGrams      Int?
  dimensions       Json?
  moderatedBy      String?
  moderationReason String?
  isFeatured       Boolean          @default(false)
  ratingAvg        Float            @default(0)
  ratingCount      Int              @default(0)
  views            Int              @default(0)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  store            Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category         Category         @relation(fields: [categoryId], references: [id])
  brand            Brand?           @relation(fields: [brandId], references: [id])
  variants         ProductVariant[]
  images           ProductImage[]
  reviews          Review[]
  wishlistItems    WishlistItem[]
  recentlyViewed   RecentlyViewed[]

  @@index([storeId])
  @@index([categoryId])
  @@index([status])
  // Brand-filtered listings and the "featured" home strip.
  @@index([brandId])
  @@index([isFeatured])
}

model ProductVariant {
  id             String          @id @default(cuid())
  productId      String
  sku            String          @unique
  name           String
  attributes     Json?
  price          Decimal         @db.Decimal(12, 2)
  compareAtPrice Decimal?        @db.Decimal(12, 2)
  saleStartsAt   DateTime?
  saleEndsAt     DateTime?
  stock          Int             @default(0)
  isActive       Boolean         @default(true)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  cartItems      CartItem[]
  flashSaleItems FlashSaleItem[]

  @@index([productId])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ---------------------------------------------------------------------------
// D. Cart, wishlist, recently viewed
// ---------------------------------------------------------------------------

model Cart {
  id         String     @id @default(cuid())
  userId     String     @unique
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  // Abandoned-cart marketing (Step 17.8): when the reminder email was sent, so
  // a cart is nudged at most once.
  remindedAt DateTime?
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
}

// Newsletter subscribers (Step 17.8). Email is the identity; userId is captured
// when a signed-in user subscribes, purely for analytics. Sending is stubbed
// through the email adapter until a provider is wired.
model NewsletterSubscriber {
  id             String    @id @default(cuid())
  email          String    @unique
  userId         String?
  locale         String    @default("ar")
  createdAt      DateTime  @default(now())
  unsubscribedAt DateTime?

  @@index([unsubscribedAt])
}

model CartItem {
  id            String         @id @default(cuid())
  cartId        String
  variantId     String
  storeId       String
  quantity      Int            @default(1)
  savedForLater Boolean        @default(false)
  cart          Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
}

model Wishlist {
  id     String         @id @default(cuid())
  userId String         @unique
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items  WishlistItem[]
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  createdAt  DateTime @default(now())
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([wishlistId, productId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  productId String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ---------------------------------------------------------------------------
// E. Orders
// ---------------------------------------------------------------------------

model Order {
  id              String               @id @default(cuid())
  buyerId         String
  addressId       String
  status          OrderStatus          @default(PENDING)
  paymentMethod   PaymentMethod
  itemsTotal      Decimal              @db.Decimal(12, 2)
  shippingTotal   Decimal              @db.Decimal(12, 2)
  discountTotal   Decimal              @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal              @db.Decimal(12, 2)
  displayCurrency Currency             @default(USD)
  exchangeRate    Decimal              @default(1) @db.Decimal(18, 6)
  displayTotal    Decimal              @db.Decimal(14, 2)
  couponId        String?
  // Buyer's optional scheduled delivery window for Hezalli Express parcels: a
  // preferred day + a time-of-day slot (MORNING / AFTERNOON / EVENING). Both are
  // set together or both null. A soft preference surfaced to dispatch + courier.
  deliveryDate    DateTime?            @db.Date
  deliverySlot    String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  buyer           User                 @relation(fields: [buyerId], references: [id])
  address         Address              @relation(fields: [addressId], references: [id])
  coupon          Coupon?              @relation(fields: [couponId], references: [id])
  subOrders       SubOrder[]
  payment         Payment?
  history         OrderStatusHistory[]
  redemptions     CouponRedemption[]

  @@index([buyerId])
  @@index([status])
  @@index([couponId])
  @@index([createdAt])
}

model SubOrder {
  id             String         @id @default(cuid())
  orderId        String
  storeId        String
  status         SubOrderStatus @default(PENDING)
  shippingMethod ShippingMethod @default(STANDARD)
  // PICKUP only: the Hezalli Point the buyer collects from (plain id — the
  // shipment's deliveryPointId FK is set when the seller ships).
  pickupPointId  String?
  itemsTotal     Decimal        @db.Decimal(12, 2)
  shippingTotal  Decimal        @db.Decimal(12, 2)
  discountTotal  Decimal        @default(0) @db.Decimal(12, 2)
  commissionRate Decimal        @default(0.10) @db.Decimal(5, 4)
  commissionAmt  Decimal        @default(0) @db.Decimal(12, 2)
  sellerNet      Decimal        @default(0) @db.Decimal(12, 2)
  completedAt    DateTime?
  autoCompleteAt DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  store          Store          @relation(fields: [storeId], references: [id])
  items          OrderItem[]
  shipment       Shipment?
  return         ReturnRequest?
  reviews        Review[]

  @@index([orderId])
  @@index([storeId])
  @@index([status])
  @@index([autoCompleteAt])
}

model OrderItem {
  id            String   @id @default(cuid())
  subOrderId    String
  variantId     String
  titleSnapshot String
  skuSnapshot   String
  unitPrice     Decimal  @db.Decimal(12, 2)
  quantity      Int
  lineTotal     Decimal  @db.Decimal(12, 2)
  subOrder      SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)

  @@index([subOrderId])
  @@index([variantId])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String?
  actor     String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// ---------------------------------------------------------------------------
// F. Payments, refunds, ledger, payouts, currency
// ---------------------------------------------------------------------------

model Payment {
  id          String        @id @default(cuid())
  orderId     String        @unique
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  amountUsd   Decimal       @db.Decimal(12, 2)
  proofUrl    String?
  reference   String?
  usdtNetwork UsdtNetwork?
  usdtTxHash  String?
  usdtAddress String?
  confirmedBy String?
  confirmedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds     Refund[]

  @@index([status])
}

model Refund {
  id          String    @id @default(cuid())
  paymentId   String?
  subOrderId  String?
  amountUsd   Decimal   @db.Decimal(12, 2)
  reason      String?
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())
  payment     Payment?  @relation(fields: [paymentId], references: [id])

  @@index([paymentId])
  @@index([subOrderId])
}

model SellerBalance {
  id           String        @id @default(cuid())
  sellerId     String        @unique
  availableUsd Decimal       @default(0) @db.Decimal(12, 2)
  pendingUsd   Decimal       @default(0) @db.Decimal(12, 2)
  seller       SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  entries      LedgerEntry[]
}

model LedgerEntry {
  id         String        @id @default(cuid())
  balanceId  String
  type       LedgerType
  amountUsd  Decimal       @db.Decimal(12, 2)
  subOrderId String?
  payoutId   String?
  note       String?
  createdAt  DateTime      @default(now())
  balance    SellerBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)

  @@index([balanceId])
  @@index([subOrderId])
  @@index([payoutId])
}

model Payout {
  id          String        @id @default(cuid())
  sellerId    String
  amountUsd   Decimal       @db.Decimal(12, 2)
  method      String
  destination Json
  status      PayoutStatus  @default(REQUESTED)
  processedBy String?
  processedAt DateTime?
  createdAt   DateTime      @default(now())
  seller      SellerProfile @relation(fields: [sellerId], references: [id])

  @@index([sellerId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// F.2 HezalliPay wallet (Step 19.1). Buyer stored-balance account. Mirrors the
// seller ledger: availableUsd is always the sum of the wallet's entries, and
// entries are immutable — balances are recomputed, never edited in place.
// See docs/19-wallet-strategy.md.
// ---------------------------------------------------------------------------

enum WalletEntryType {
  TOP_UP // cash-in via a rail, admin-confirmed (Step 19.3)
  PAYMENT // spent on an order (Step 19.2)
  REFUND // order refunded to wallet (Step 19.1)
  CASHBACK // loyalty / promo credit (Step 19.5)
  CASHOUT // withdrawn to a rail (Step 19.4)
  ADJUSTMENT // admin correction (audited)
  SELLER_EARNINGS // swept in from the seller balance (Step 19.5+)
  TRANSFER_OUT // sent to another user via P2P (Step 19.5+, licensed only)
  TRANSFER_IN // received from another user via P2P (Step 19.5+, licensed only)
  BILL_PAYMENT // paid a utility bill from the wallet (Step 19.7)
  AIRTIME_TOPUP // bought mobile credit from the wallet (Step 19.7)
  BILL_REFUND // a failed bill/airtime purchase returned to the wallet (Step 19.7)
}

enum WalletTopUpStatus {
  AWAITING_CONFIRMATION // buyer submitted proof; admin review pending
  CONFIRMED // credited to the wallet
  REJECTED // declined; nothing credited
}

model Wallet {
  id           String             @id @default(cuid())
  userId       String             @unique
  availableUsd Decimal            @default(0) @db.Decimal(12, 2)
  frozen       Boolean            @default(false) // AML / dispute hold
  // Wallet PIN (Step 19.9): scrypt hash (same format as passwordHash). Required
  // to authorize every outflow. Lockout backs off brute force: after too many
  // wrong tries `pinLockedUntil` blocks attempts for a cool-off window.
  pinHash        String?
  pinFailedCount Int              @default(0)
  pinLockedUntil DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries      WalletEntry[]
  topUps       WalletTopUp[]
  withdrawals  WalletWithdrawal[]
  sent         WalletTransfer[]   @relation("SentTransfers")
  received     WalletTransfer[]   @relation("ReceivedTransfers")
  billPayments WalletBillPayment[]
}

// Peer-to-peer wallet transfer (Step 19.5+). LICENSED ONLY — money transmission
// is regulated; kept off by the wallet_p2p_enabled setting (default false) and
// gated on VERIFIED KYC. This row is the audit trail; the balance moves via a
// TRANSFER_OUT entry on the sender and a TRANSFER_IN entry on the recipient.
model WalletTransfer {
  id           String   @id @default(cuid())
  fromWalletId String
  toWalletId   String
  amountUsd    Decimal  @db.Decimal(12, 2)
  note         String?
  createdAt    DateTime @default(now())
  fromWallet   Wallet   @relation("SentTransfers", fields: [fromWalletId], references: [id], onDelete: Cascade)
  toWallet     Wallet   @relation("ReceivedTransfers", fields: [toWalletId], references: [id], onDelete: Cascade)

  @@index([fromWalletId])
  @@index([toWalletId])
}

enum WalletRequestStatus {
  PENDING // awaiting payment
  PAID // fulfilled via a wallet transfer
  CANCELLED // withdrawn by the requester
}

// "Request money" (Step 19.6). A user asks another user to pay them; the payer
// opens a shareable link / QR and pays from their wallet, which runs the normal
// P2P transfer and marks the request PAID. Gated by the same wallet_p2p_enabled
// toggle as direct transfers.
model WalletPaymentRequest {
  id          String              @id @default(cuid())
  requesterId String // User.id who is requesting money
  amountUsd   Decimal             @db.Decimal(12, 2)
  note        String?
  status      WalletRequestStatus @default(PENDING)
  payerId     String? // User.id who paid it
  paidAt      DateTime?
  createdAt   DateTime            @default(now())

  @@index([requesterId])
  @@index([status])
}

enum WalletBillKind {
  BILL // a utility / service bill: electricity, water, internet, landline…
  AIRTIME // mobile credit top-up for a phone number
}

enum WalletBillStatus {
  PENDING // submitted; wallet debited (reserved) awaiting fulfillment
  COMPLETED // provider fulfilled (admin-confirmed for now)
  FAILED // couldn't fulfill → funds returned to the wallet
}

// Bill payment & airtime top-up (Step 19.7). A provider-ready framework: the
// buyer picks a biller/operator, enters the account/phone + amount, and pays
// from their HezalliPay wallet. The wallet is debited immediately (reserved)
// and the row goes PENDING; an admin confirms fulfillment (COMPLETED) or fails
// it, which refunds the wallet. Wire a real biller/telco aggregator API later
// by auto-transitioning PENDING → COMPLETED/FAILED. Gated by wallet_bills_enabled
// (default off). See docs/19-wallet-strategy.md §5.
model WalletBillPayment {
  id          String           @id @default(cuid())
  walletId    String
  kind        WalletBillKind
  biller      String // biller/operator slug from lib/wallet-billers.ts
  account     String // account number (bill) or phone number (airtime) being paid
  amountUsd   Decimal          @db.Decimal(12, 2)
  status      WalletBillStatus @default(PENDING)
  note        String?
  reference   String? // provider confirmation reference (admin fills on complete)
  reviewedBy  String?
  reviewNote  String?
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  wallet      Wallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
  @@index([kind])
}

// Cash-out to a rail (Step 19.4). Gated on VERIFIED KYC. The wallet is debited
// (reserved) at request time — balances are spendable, so the funds are held
// immediately to prevent double-spend; a rejection returns them. Reuses
// PayoutStatus. See docs/19-wallet-strategy.md §4 (regulatory + operational).
model WalletWithdrawal {
  id          String       @id @default(cuid())
  walletId    String
  amountUsd   Decimal      @db.Decimal(12, 2)
  method      String // destination kind: bank | wallet | usdt
  destination Json
  status      PayoutStatus @default(REQUESTED)
  reviewedBy  String?
  reviewNote  String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

// Cash-in over a rail (Step 19.3). Mirrors the Payment proof flow: the buyer
// submits a reference/tx hash, an admin confirms, and a TOP_UP WalletEntry is
// written. See docs/19-wallet-strategy.md §4 (regulatory).
model WalletTopUp {
  id          String            @id @default(cuid())
  walletId    String
  method      PaymentMethod // LOCAL_WALLET | BANK_TRANSFER | USDT
  amountUsd   Decimal           @db.Decimal(12, 2)
  status      WalletTopUpStatus @default(AWAITING_CONFIRMATION)
  reference   String?
  usdtNetwork UsdtNetwork?
  usdtTxHash  String?
  reviewedBy  String?
  reviewNote  String?
  confirmedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([status])
}

// Immutable. availableUsd MUST equal the sum of entries — never edit directly.
model WalletEntry {
  id         String          @id @default(cuid())
  walletId   String
  type       WalletEntryType
  amountUsd  Decimal         @db.Decimal(12, 2) // +credit / -debit
  orderId    String? // set for PAYMENT / REFUND
  subOrderId String?
  note       String?
  // Link to the source record so a transaction detail / receipt can enrich the
  // entry (transfer | bill | topup | withdrawal). `refId` is that record's id.
  refType    String? // transfer | bill | topup | withdrawal
  refId      String?
  // Unguessable token minted the first time the owner shares this transaction's
  // receipt; the public /receipt/[token] page resolves it (Step 19.8).
  receiptToken String?       @unique
  createdAt  DateTime        @default(now())
  wallet     Wallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([orderId])
  @@index([subOrderId])
}

// Biometric step-up via WebAuthn / passkeys (Step 21). A registered platform
// authenticator (Face ID / Touch ID / fingerprint / Windows Hello) that can
// authorize wallet outflows instead of typing the PIN. Only the PUBLIC key is
// stored — the biometric never leaves the device. The PIN remains as a fallback.
model WalletCredential {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique // base64url of the authenticator credential ID
  publicKey    String // base64url of the COSE public key
  counter      Int       @default(0) // signature counter (clone-detection)
  transports   String[] // e.g. ["internal", "hybrid"]
  label        String? // friendly device label
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Short-lived server-issued WebAuthn challenge (one in-flight per user). Consumed
// on the matching register/authenticate response; expired ones are ignored.
model WalletWebauthnChallenge {
  userId    String   @id
  challenge String
  purpose   String // "register" | "auth"
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  Currency @unique
  rate      Decimal  @db.Decimal(18, 6)
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

// ---------------------------------------------------------------------------
// G. Shipping & delivery
// ---------------------------------------------------------------------------

model Carrier {
  id              String     @id @default(cuid())
  name            String
  trackingUrl     String?
  platformManaged Boolean    @default(false)
  shipments       Shipment[]
}

// A courier's last shared location, mapped to the nearest governorate for
// locality-based dispatch. One row per driver; refreshed while they share.
model CourierLocation {
  userId      String   @id
  lat         Float
  lng         Float
  governorate String
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([governorate])
}

// Delivery tier a buyer picks per store group at checkout. STANDARD is the
// zone-based rate; EXPRESS is the faster, premium-priced option (our own
// Hezalli Express carrier); PICKUP means the buyer collects from a Hezalli
// Point themselves (docs/DELIVERY-POINTS.md §6) — see lib/shipping.ts.
enum ShippingMethod {
  STANDARD
  EXPRESS
  PICKUP
}

model ShippingZone {
  id           String         @id @default(cuid())
  name         String
  governorates String[]
  rates        ShippingRate[]
}

model ShippingRate {
  id       String       @id @default(cuid())
  storeId  String
  zoneId   String
  feeUsd   Decimal      @db.Decimal(12, 2)
  freeOver Decimal?     @db.Decimal(12, 2)
  // Optional express-tier fee for this zone. Null → the store hasn't set its own
  // express price and the platform default (default_express_fee) applies.
  expressFeeUsd Decimal? @db.Decimal(12, 2)
  store    Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  zone     ShippingZone @relation(fields: [zoneId], references: [id])

  @@unique([storeId, zoneId])
  @@index([storeId])
}

model Shipment {
  id              String          @id @default(cuid())
  subOrderId      String          @unique
  carrierId       String?
  trackingNumber  String?
  status          ShipmentStatus  @default(PENDING)
  platformManaged Boolean         @default(false)
  // Assigned Hezalli Express courier (null = unassigned / third-party carrier).
  driverId        String?
  // Route via a partner hub (null = direct seller → courier).
  deliveryPointId String?
  // Two-hop line-haul (docs §14): the point near the SELLER where the parcel
  // enters the network before being carried to deliveryPointId. Plain id (no
  // FK) — resolved manually to keep DeliveryPoint relations simple.
  originPointId   String?
  // Which point physically holds the parcel right now (null = not at a hub).
  // Set on every receive scan, cleared on handover / delivery / RTS.
  atPointId       String?
  // Short random code for the optional buyer-QR proof of delivery.
  deliveryCode    String?         @unique
  // Buyer's requested redelivery day + note after a failed attempt.
  redeliverAt     DateTime?
  redeliverNote   String?
  // One-shot guards for the stale-parcel sweep (docs §20): when the buyer was
  // reminded to collect, and when the hold was flagged (window expiry / stuck).
  pickupRemindedAt DateTime?
  staleFlaggedAt   DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  // How many doorstep attempts the courier has made (failed + the final one).
  attemptCount    Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  subOrder        SubOrder        @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  carrier         Carrier?        @relation(fields: [carrierId], references: [id])
  driver          User?           @relation("CourierShipments", fields: [driverId], references: [id])
  deliveryPoint   DeliveryPoint?  @relation(fields: [deliveryPointId], references: [id])
  events          ShipmentEvent[]
  attempts        DeliveryAttempt[]
  deliveryRating  DeliveryRating?

  @@index([driverId])
  @@index([carrierId])
  @@index([deliveryPointId])
  @@index([originPointId])
  @@index([atPointId])
}

// A buyer's rating of the courier who delivered their Hezalli Express parcel.
// One per shipment (the buyer may update it). Aggregated per courier for the
// admin fleet view. courierId/buyerId are plain ids (no FK churn on User).
model DeliveryRating {
  id         String   @id @default(cuid())
  shipmentId String   @unique
  courierId  String
  buyerId    String
  stars      Int // 1–5
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  shipment   Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([courierId])
}

// One doorstep delivery attempt. FAILED records why (unreachable, refused,
// wrong address, rescheduled, …); DELIVERED records proof (who received it and
// an optional photo). Gives the parcel a real attempt history instead of a
// single terminal flag, and powers retry + COD dispute evidence.
model DeliveryAttempt {
  id            String          @id @default(cuid())
  shipmentId    String
  courierId     String? // the driver at the time (plain id; no FK churn on User)
  outcome       DeliveryOutcome
  reason        String? // FAILED: unreachable | refused | wrong_address | rescheduled | other
  recipientName String? // DELIVERED: who took the parcel
  proofPhotoKey String? // DELIVERED: storage key of a doorstep photo
  codeVerified  Boolean         @default(false) // DELIVERED: buyer's delivery code/QR was verified
  note          String?
  createdAt     DateTime        @default(now())
  shipment      Shipment        @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

model ShipmentEvent {
  id         String         @id @default(cuid())
  shipmentId String
  status     ShipmentStatus
  location   String?
  note       String?
  createdAt  DateTime       @default(now())
  shipment   Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId])
}

// ---------------------------------------------------------------------------
// H. Reviews, returns, disputes
// ---------------------------------------------------------------------------

model Review {
  id         String        @id @default(cuid())
  productId  String
  subOrderId String
  buyerId    String
  rating     Int
  comment    String?
  storeReply String?
  hidden     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  product    Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  subOrder   SubOrder      @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  buyer      User          @relation(fields: [buyerId], references: [id])
  images     ReviewImage[]

  @@unique([subOrderId, productId, buyerId])
  @@index([productId])
}

model ReviewImage {
  id       String @id @default(cuid())
  reviewId String
  url      String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model ReturnRequest {
  id         String       @id @default(cuid())
  subOrderId String       @unique
  buyerId    String
  status     ReturnStatus @default(REQUESTED)
  reason     String
  evidence   Json?
  resolution String?
  refundId   String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  subOrder   SubOrder     @relation(fields: [subOrderId], references: [id], onDelete: Cascade)
  buyer      User         @relation(fields: [buyerId], references: [id])
  items      ReturnItem[]
  dispute    Dispute?

  @@index([buyerId])
}

model ReturnItem {
  id            String        @id @default(cuid())
  returnId      String
  orderItemId   String
  quantity      Int
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
}

model Dispute {
  id            String           @id @default(cuid())
  returnId      String           @unique
  status        DisputeStatus    @default(OPEN)
  openedBy      String
  assignedTo    String?
  verdict       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  returnRequest ReturnRequest    @relation(fields: [returnId], references: [id], onDelete: Cascade)
  messages      DisputeMessage[]

  @@index([status])
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  senderId    String
  body        String
  attachments Json?
  createdAt   DateTime @default(now())
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
}

// ---------------------------------------------------------------------------
// I. Chat & notifications
// ---------------------------------------------------------------------------

model Conversation {
  id         String    @id @default(cuid())
  buyerId    String
  storeId    String
  subOrderId String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  buyer      User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  messages   Message[]

  @@unique([buyerId, storeId])
  @@index([storeId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  attachments    Json?
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// J. Promotions
// ---------------------------------------------------------------------------

model Coupon {
  id           String             @id @default(cuid())
  code         String             @unique
  scope        CouponScope
  storeId      String?
  discountType DiscountType
  value        Decimal            @db.Decimal(12, 2)
  maxDiscountUsd Decimal?         @db.Decimal(12, 2)
  minSpendUsd  Decimal?           @db.Decimal(12, 2)
  maxUses      Int?
  usedCount    Int                @default(0)
  perUserLimit Int?
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  store        Store?             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  redemptions  CouponRedemption[]
  orders       Order[]

  @@index([storeId])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  userId    String
  orderId   String
  createdAt DateTime @default(now())
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
  @@index([couponId])
}

model FlashSale {
  id       String          @id @default(cuid())
  name     Json
  startsAt DateTime
  endsAt   DateTime
  isActive Boolean         @default(true)
  items    FlashSaleItem[]
}

model FlashSaleItem {
  id          String         @id @default(cuid())
  flashSaleId String
  variantId   String
  salePrice   Decimal        @db.Decimal(12, 2)
  stockLimit  Int?
  soldCount   Int            @default(0)
  flashSale   FlashSale      @relation(fields: [flashSaleId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([flashSaleId])
  @@index([variantId])
}

// ---------------------------------------------------------------------------
// K. Content & admin
// ---------------------------------------------------------------------------

model CmsPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     Json
  body      Json
  published Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

model Banner {
  id        String    @id @default(cuid())
  image     String
  linkUrl   String?
  title     Json?
  position  String
  isActive  Boolean   @default(true)
  sortOrder Int       @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  action    String
  entity    String
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([actorId])
}

// Short-lived conversation memory for messaging-channel bots (Telegram, and
// later WhatsApp). One row per (platform, chatId); `messages` holds the last
// few turns as a JSON array of { role, text } so follow-up questions keep
// context. Not tied to a Hezalli account — the chat is anonymous by default.
model BotConversation {
  id        String   @id @default(cuid())
  platform  String
  chatId    String
  messages  Json     @default("[]")
  // Recent request timestamps (ms) inside the rolling hourly window — the
  // per-user rate limit. Trimmed on each turn.
  rateHits  Json     @default("[]")
  // Linked Hezalli account (via the /link flow) — lets the bot answer order
  // questions for this chat. Null = anonymous.
  userId    String?
  // One-time code + expiry for the account-linking handshake (set by /link,
  // consumed on the website while signed in).
  linkCode          String?   @unique
  linkCodeExpiresAt DateTime?
  // Lifetime per-chat counters (light analytics).
  msgCount  Int      @default(0)
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([platform, chatId])
  @@index([userId])
  @@index([updatedAt])
}

// Daily aggregate of bot LLM usage, used for the global daily message backstop
// and the monthly spend estimate/cap. One row per calendar day (UTC).
model BotDailyUsage {
  id        String   @id @default(cuid())
  day       String   @unique // YYYY-MM-DD (UTC)
  messages  Int      @default(0)
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  // Gemini TTS output (audio) tokens, priced separately from text output.
  ttsTokens Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
